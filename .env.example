# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# GitHub Token (create at https://github.com/settings/tokens)
GITHUB_TOKEN="your_github_token"

# Gemini API Key (https://ai.google.dev/)
GEMINI_API_KEY="your_gemini_api_key"

# Caching – Vercel KV or similar (optional for local dev)
KV_REST_API_READ_ONLY_TOKEN=""
KV_REST_API_TOKEN=""
KV_REST_API_URL=""
KV_URL=""
REDIS_URL=""

# Blob storage (optional)
BLOB_READ_WRITE_TOKEN=""

# Admin – GitHub username that can access /admin
ADMIN_GITHUB_USERNAME="your_github_username"

# NextAuth (GitHub OAuth)
AUTH_GITHUB_ID="your_github_oauth_client_id"
AUTH_GITHUB_SECRET="your_github_oauth_client_secret"
AUTH_SECRET="your_random_32_char_secret"

# Postgres (e.g. Neon)
DATABASE_URL="your_database_url"
DIRECT_URL="your_direct_url"

# Resend (email)
RESEND_API_KEY="your_resend_api_key"
RESEND_FROM_EMAIL="GitPulse <onboarding@yourdomain.com>"
RESEND_WEBHOOK_SECRET=""

# Internal
EMAIL_RETRY_JOB_SECRET=""
CRON_SECRET=""
